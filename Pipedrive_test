// ── Crear actividad Pipedrive ─────────────────────────────────────
async function crearActividad(unidad) {
  const subject = `TEST - ${unidad.plate} - Sin reporte +${unidad.dias_sin_reporte ?? DIAS_UMBRAL} días`;
  const nota = [
    `🧪 PRUEBA — eliminar tras verificar`,
    `🚗 Unidad: ${unidad.plate}`,
    unidad.uid ? `📡 UID/IMEI: ${unidad.uid}` : null,
    unidad.ultimo_reporte
      ? `📅 Último reporte: ${new Date(unidad.ultimo_reporte).toLocaleString('es-CL')}`
      : `📅 Último reporte: Sin registro`,
    unidad.dias_sin_reporte != null
      ? `⏱ Días sin reportar: ${unidad.dias_sin_reporte}`
      : `⏱ Días sin reportar: Sin datos`,
    `⚙️ Script de prueba Síguelo GPS`,
  ].filter(Boolean).join('\n');

  const url = `${PD_BASE}/activities?api_token=${PIPEDRIVE_KEY}`;
  const res  = await fetch(url, {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify({
      subject,
      type:    'unidades_sin_reportar',
      user_id: PD_OWNER_ID,
      done:    false,
      note:    nota,
    }),
  });
  const json = await res.json();
  if (!json.success) throw new Error(json.error || 'Pipedrive error');
  return json.data;
}

// ── Main ──────────────────────────────────────────────────────────
(async () => {
  let eid = null;
  try {
    eid = await wialonLogin();
    const unidades = await getUnidadesSinReporte(eid);

    console.log(`\n[Wialon] Encontradas ${unidades.length} unidades sin reporte ≥${DIAS_UMBRAL} días:\n`);
    unidades.forEach(u => {
      const dt = u.ultimo_reporte ? new Date(u.ultimo_reporte).toLocaleDateString('es-CL') : 'Sin datos';
      console.log(`  • ${u.plate} — ${u.dias_sin_reporte ?? '?'} días (último: ${dt})`);
    });

    if (!unidades.length) {
      console.log('\n[!] No hay unidades que cumplan el criterio en los primeros resultados.');
      return;
    }

    console.log('\n[Pipedrive] Creando actividades de prueba...\n');
    for (const u of unidades) {
      try {
        const act = await crearActividad(u);
        console.log(`  ✓ ${u.plate} → actividad ID ${act.id} creada`);
        await new Promise(r => setTimeout(r, 200));
      } catch (err) {
        console.error(`  ✗ ${u.plate} → ${err.message}`);
      }
    }

    console.log('\n✅ Prueba completada. Verifica las actividades en Pipedrive.');
    console.log('   Todas tienen el prefijo "TEST -" para identificarlas y eliminarlas fácilmente.');

  } catch (err) {
    console.error('\n❌ Error:', err.message);
  } finally {
    if (eid) {
      await wialonLogout(eid);
      console.log('[Wialon] Sesión cerrada.');
    }
  }
})();
