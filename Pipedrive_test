const WIALON_TOKEN    = 'cd5f16a83fd0572dc66fb952acf02b6b23114E997AB305827DC8191962A9E64AB4623FFF';
const PIPEDRIVE_KEY   = '219c4e20f0d25fee0abfa68e3f38f0c5410e0e14';
const DIAS_UMBRAL     = 15;
const LIMITE_PRUEBA   = 5;   // solo 5 unidades de prueba
const WIALON_BASE     = 'https://hst-api.wialon.com/wialon/ajax.html';
const PD_BASE         = 'https://api.pipedrive.com/v1';
const PD_OWNER_ID     = 24878669; // Gerald

// ── Wialon login ─────────────────────────────────────────────────
async function wialonLogin() {
  const params = new URLSearchParams({
    svc:    'token/login',
    params: JSON.stringify({ token: WIALON_TOKEN }),
  });
  const res  = await fetch(WIALON_BASE, { method: 'POST', body: params });
  const json = await res.json();
  if (json.error) throw new Error(`Wialon login error ${json.error}: ${json.reason || ''}`);
  console.log(`[Wialon] Login OK — eid: ${json.eid.slice(0,8)}...`);
  return json.eid;
}

// ── Wialon logout ────────────────────────────────────────────────
async function wialonLogout(eid) {
  const params = new URLSearchParams({ svc: 'core/logout', params: '{}', sid: eid });
  await fetch(WIALON_BASE, { method: 'POST', body: params }).catch(() => {});
}

// ── Buscar unidades Wialon sin reporte ────────────────────────────
async function getUnidadesSinReporte(eid) {
  const ahora = Math.floor(Date.now() / 1000);
  const umbral = ahora - DIAS_UMBRAL * 86400;
  const resultado = [];
  let from = 0;

  console.log('[Wialon] Buscando unidades...');

  while (resultado.length < LIMITE_PRUEBA) {
    const params = new URLSearchParams({
      svc: 'core/search_items',
      params: JSON.stringify({
        spec: { itemsType: 'avl_unit', propName: 'sys_name', propValueMask: '*', sortType: 'sys_name' },
        force: 1, flags: 4194305, from, to: from + 50,
      }),
      sid: eid,
    });

    const res  = await fetch(WIALON_BASE, { method: 'POST', body: params });
    const json = await res.json();
    if (json.error) throw new Error(`Wialon search error ${json.error}`);

    const items = json.items || [];
    const total = json.totalItemsCount || 0;

    for (const u of items) {
      if (resultado.length >= LIMITE_PRUEBA) break;
