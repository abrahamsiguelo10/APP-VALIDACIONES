/**
 * src/routes/pipedrive.js
 *
 * Detecta unidades sin reporte GPS +15 días usando la API de Wialon
 * y crea actividades en Pipedrive tipo "UNIDADES SIN REPORTAR".
 *
 * Flujo:
 *  1. Login en Wialon con token → obtiene eid (session)
 *  2. Pagina core/search_items (flags:4194305) para obtener todas las unidades
 *  3. Filtra las que pos.t sea nulo o >= 15 días sin reporte
 *  4. Cruza por nombre/uid con units de Supabase para enriquecer con cliente
 *  5. Verifica duplicados en Pipedrive y crea actividad si no existe
 *
 * Variables de entorno Railway:
 *   WIALON_TOKEN      — token de API Wialon
 *   PIPEDRIVE_API_KEY — API key Pipedrive
 */

'use strict';

const router    = require('express').Router();
const { query } = require('../db/pool');
const { requireAuth, requireRole } = require('../middleware/auth');

// ── Constantes Pipedrive ──────────────────────────────────────────
const PD_BASE          = 'https://api.pipedrive.com/v1';
const PD_OWNER_ID      = 24878669;   // Gerald — integraciones@siguelogps.cl
const DIAS_SIN_REPORTE = 15;

// ── Constantes Wialon ─────────────────────────────────────────────
const WIALON_BASE  = 'https://hst-api.wialon.com/wialon/ajax.html';
const WIALON_FLAGS = 4194305; // 1 (nombre) + 4194304 (pos/último mensaje)
const WIALON_PAGE  = 100;     // unidades por página

// ── Helper Pipedrive ─────────────────────────────────────────────
async function pdFetch(path, options = {}) {
  const apiKey = process.env.PIPEDRIVE_API_KEY;
  if (!apiKey) throw new Error('PIPEDRIVE_API_KEY no configurada');
  const sep = path.includes('?') ? '&' : '?';
  const url = `${PD_BASE}${path}${sep}api_token=${apiKey}`;
  const res  = await fetch(url, {
    ...options,
    headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
    signal: AbortSignal.timeout ? AbortSignal.timeout(10000) : undefined,
  });
  const json = await res.json().catch(() => ({}));
  if (!json.success) throw new Error(json.error || `Pipedrive error ${path}`);
  return json;
}

// ── Login Wialon → eid ────────────────────────────────────────────
async function wialonLogin() {
  const token = process.env.WIALON_TOKEN;
  if (!token) throw new Error('WIALON_TOKEN no configurada');

  const params = new URLSearchParams({
    svc:    'token/login',
    params: JSON.stringify({ token }),
  });
  const res  = await fetch(WIALON_BASE, {
    method: 'POST',
    body:   params,
    signal: AbortSignal.timeout ? AbortSignal.timeout(10000) : undefined,
  });
  const json = await res.json();
  if (json.error) throw new Error(`Wialon login error: ${json.error} ${json.reason || ''}`);
  return json.eid;
}

// ── Logout Wialon ─────────────────────────────────────────────────
async function wialonLogout(eid) {
  try {
    const params = new URLSearchParams({ svc: 'core/logout', params: '{}', sid: eid });
    await fetch(WIALON_BASE, { method: 'POST', body: params });
  } catch (_) {}
}

// ── Obtener todas las unidades Wialon con su último reporte ───────
async function getWialonUnidades(eid) {
  const ahora = Math.floor(Date.now() / 1000);
  const unidades = [];
  let from = 0;

  while (true) {
    const params = new URLSearchParams({
      svc: 'core/search_items',
      params: JSON.stringify({
        spec: {
          itemsType:      'avl_unit',
          propName:       'sys_name',
          propValueMask:  '*',
          sortType:       'sys_name',
        },
        force: 1,
        flags: WIALON_FLAGS,
        from,
        to: from + WIALON_PAGE,
      }),
      sid: eid,
    });

    const res  = await fetch(WIALON_BASE, {
      method: 'POST',
      body:   params,
      signal: AbortSignal.timeout ? AbortSignal.timeout(15000) : undefined,
    });
    const json = await res.json();
    if (json.error) throw new Error(`Wialon search_items error: ${json.error}`);

